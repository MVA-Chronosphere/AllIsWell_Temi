<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Hospital Alliswell Theme -->
    <style name="Theme.AlliswellTemi" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorSecondaryVariant">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/card_background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Customize your theme here -->
    </style>
</resources>