<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- HEADER BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Hospital Logo/Text (Left) -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/hospital_title"
            android:textColor="@color/primary_blue"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Status Text (Right) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_online"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginEnd="16dp" />

        <!-- Battery Status (Right) -->
        <TextView
            android:id="@+id/battery_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/battery_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- MAIN CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- HERO SECTION -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/welcome_title"
                android:textColor="@color/text_dark"
                android:textSize="36sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/welcome_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginBottom="40dp" />

            <!-- PRIMARY ACTION BUTTON -->
            <Button
                android:id="@+id/btn_talk"
                android:layout_width="320dp"
                android:layout_height="72dp"
                android:text="@string/talk_button"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/primary_button_bg"
                android:elevation="4dp"
                android:layout_marginBottom="48dp" />

            <!-- FEATURE CARDS GRID (2x3) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Column 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="8dp">

                    <!-- Find a Doctor -->
                    <Button
                        android:id="@+id/btn_find_doctor"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="@string/doctors_departments"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/feature_card_bg"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <!-- Appointments -->
                    <Button
                        android:id="@+id/btn_appointments"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="@string/book_appointment"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/feature_card_bg"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <!-- Help Desk -->
                    <Button
                        android:id="@+id/btn_help_desk"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="@string/hospital_info"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/feature_card_bg"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Column 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="8dp">

                    <!-- Departments -->
                    <Button
                        android:id="@+id/btn_departments"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="@string/doctors_departments"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/feature_card_bg"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <!-- Emergency -->
                    <Button
                        android:id="@+id/btn_emergency"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="@string/emergency"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/emergency_card_bg"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <!-- Language -->
                    <Button
                        android:id="@+id/btn_language"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="@string/language"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/feature_card_bg"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

            <!-- ANNOUNCEMENTS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginTop="40dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/announcements_title"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/announcements_text"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
